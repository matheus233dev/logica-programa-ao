idade = int(input("Digite a idade: "))

if idade >= 18:
    print("A pessoa é maior de idade.")
else:
    faltam = 18 - idade
    print(f"Faltam {faltam} anos para atingir a maioridade.")

n1 = int(input("Digite o primeiro número: "))
